<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.student.mapper.UserMapper">
    <resultMap id="UserResultMap" type="com.example.student.entity.SystemUser">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password_hash" property="passwordHash"/>
        <result column="display_name" property="displayName"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <sql id="BaseColumns">
        id, username, password_hash, display_name, created_at, updated_at
    </sql>

    <select id="selectById" resultMap="UserResultMap">
        select <include refid="BaseColumns"/>
        from system_user
        where id = #{id}
    </select>

    <select id="selectByUsername" resultMap="UserResultMap">
        select <include refid="BaseColumns"/>
        from system_user
        where username = #{username}
        limit 1
    </select>

    <insert id="insert" parameterType="com.example.student.entity.SystemUser" useGeneratedKeys="true" keyProperty="id">
        insert into system_user
        (username, password_hash, display_name)
        values
        (#{username}, #{passwordHash}, #{displayName})
    </insert>
</mapper>
